{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/paper-annotations.schema.json",
  "title": "Paper Annotations",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paper",
    "report",
    "concepts",
    "blocks",
    "annotations"
  ],
  "properties": {
    "paper": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "paper_id",
        "title",
        "source_url",
        "source_kind"
      ],
      "properties": {
        "paper_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "minLength": 1
        },
        "source_kind": {
          "type": "string",
          "enum": [
            "arxiv_html",
            "arxiv_text"
          ]
        }
      }
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_type",
        "primary_focus",
        "one_sentence_summary",
        "executive_summary",
        "problem_and_scope",
        "method_and_architecture",
        "training_and_data",
        "evaluation_and_evidence",
        "novelty_and_lineage",
        "limitations_and_risks",
        "practical_takeaways",
        "open_questions"
      ],
      "properties": {
        "document_type": {
          "type": "string",
          "minLength": 1
        },
        "primary_focus": {
          "type": "string",
          "minLength": 1
        },
        "one_sentence_summary": {
          "type": "string",
          "minLength": 1
        },
        "executive_summary": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "problem_and_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "method_and_architecture": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "training_and_data": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evaluation_and_evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "novelty_and_lineage": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "limitations_and_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "practical_takeaways": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "concept_id",
          "name",
          "summary"
        ],
        "properties": {
          "concept_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "block_id",
          "section_label",
          "order",
          "text"
        ],
        "properties": {
          "block_id": {
            "type": "string",
            "minLength": 1
          },
          "section_label": {
            "type": "string",
            "minLength": 1
          },
          "order": {
            "type": "integer",
            "minimum": 0
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "annotation_id",
          "block_id",
          "anchor_text",
          "label",
          "kind",
          "analysis",
          "concept_ids",
          "confidence",
          "evidence"
        ],
        "properties": {
          "annotation_id": {
            "type": "string",
            "minLength": 1
          },
          "block_id": {
            "type": "string",
            "minLength": 1
          },
          "anchor_text": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "extracted_claim",
              "model_inference",
              "mechanistic_explanation",
              "method_detail",
              "limitation",
              "implication"
            ]
          },
          "analysis": {
            "type": "string",
            "minLength": 1
          },
          "concept_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "quote",
                "reason",
                "source_ref"
              ],
              "properties": {
                "quote": {
                  "type": "string",
                  "minLength": 1
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                },
                "source_ref": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
